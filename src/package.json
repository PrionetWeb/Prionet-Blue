    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "gh-pages": "^6.2.0"
  },
  "keywords": [
    "medical-debt",
    "healthcare",
    "payment-management",
    "patient-portal",
    "HIPAA-compliant",
    "debt-management",
    "healthcare-practitioners"
  ],
